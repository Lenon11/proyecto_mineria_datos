# ==============================
# Data Mining specific ignores
# ==============================

# Ignorar solo la carpeta raw
data/raw/
datasets/raw/

# Pero mantener el resto de data/
!data/processed/
!data/interim/
!data/.gitkeep

# Large model files
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib
*.pth
*.pt
*.onnx
*.pb
*.tflite

# Data processing artifacts
# Data processing artifacts - Excluir CSVs solo en data/raw/
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.parquet
data/raw/*.feather
data/raw/*.json
data/raw/*.jsonl

# Pero permitir CSVs en processed, interim y datasets
!data/processed/*.csv
!data/processed/*.xlsx
!data/processed/*.parquet
!data/interim/*.csv
!data/interim/*.xlsx
!data/interim/*.parquet
!datasets/*.csv
!datasets/*.xlsx

# Para el resto del proyecto, ignorar archivos de datos (excepto notebooks)
*.xlsx
*.xls
*.parquet
*.feather
*.json
*.jsonl
!*.ipynb
*.db
*.sqlite
*.sqlite3

# Temporary data files
*.tmp
*.temp
*.cache
*.cached

# Output directories
/output/
/results/
/figures/
/plots/
!output/.gitkeep
!results/.gitkeep
!figures/.gitkeep
!plots/.gitkeep

# MLflow
mlruns/
mlartifacts/

# DVC
.dvc/
*.dvc
!*.dvc
.dvcignore
.dvc/tmp/

# Weights & Biases
wandb/

# TensorBoard
logs/
lightning_logs/

# Ray
ray_results/

# Sacred
sacred/
runs/